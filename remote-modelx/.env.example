# Required, no default. Embedding model to pull/warm into Ollama.
MODEL_EMBED=

# Optional. Instruct model to pull/warm into Ollama -- leave unset if you
# only need embeddings (ollama-pull skips it instead of failing).
MODEL_INSTRUCT_INTERNAL=

# Optional. Host-published port for Ollama.
#OLLAMA_PORT=11434

# Required, no default. Cross-encoder model, pulled from Hugging Face on
# first request (not baked into the image).
MODEL_RERANKER=BAAI/bge-reranker-v2-m3

# Optional. Host-published port for the reranker.
#RERANKER_PORT=50051

# Optional. Must match the `cpus:` limit on the reranker service in
# docker-compose.yml.
#RERANKER_NUM_THREADS=3

# Optional. One of Python logging's level names: DEBUG, INFO, WARNING,
# ERROR, CRITICAL. Applies to the reranker only (Ollama has its own logging).
#LOG_LEVEL=INFO

# Optional. otel-collector OTLP gRPC endpoint, e.g. http://otel-collector:4317
# Applies to the reranker only.
#OTEL_EXPORTER_OTLP_ENDPOINT=
