# Full reference for every variable: README.md's "Configuration" section.

# Required, no default.
MODEL_EMBED=embeddinggemma:300m
QDRANT_COLLECTION=content

# Required only when services/mcp_server/config.yml's search_tools.backend.type is "ollama".
MODEL_INSTRUCT_INTERNAL=

MODEL_RERANKER=BAAI/bge-reranker-v2-m3

# Optional. Point at an external instance instead of the local container.
#OLLAMA_HOST=ollama
#OLLAMA_PORT=11434
#RERANKER_HOST=reranker
#RERANKER_PORT=50051

# Optional. Host-exposed ports.
#QDRANT_HTTP_PORT=6333
#QDRANT_GRPC_PORT=6334
#OPEN_WEBUI_PORT=3000
#MCP_SERVER_PORT=8000
#PIPELINES_PORT=9099

PIPELINES_API_KEY=changeme

# Optional. false = incremental ingest, true = full rebuild (make ingest-force sets this itself).
FORCE_INGEST=false

# Required only for search_tools.backend.type "anthropic_token"/"anthropic_subscription"
# or anthropic_chat.enabled -- see README's "Claude subscription auth" section.
ANTHROPIC_API_KEY=
CLAUDE_CODE_OAUTH_TOKEN=
MODEL_CHAT=

# One of Python logging's level names: DEBUG, INFO, WARNING, ERROR, CRITICAL.
LOG_LEVEL=INFO

# Optional. Monitoring profile only (make monitoring-up).
#TEMPO_PORT=3200
#LOKI_PORT=3100
#PROMETHEUS_PORT=9090
#CADVISOR_PORT=8085
#NODE_EXPORTER_PORT=9101
#GRAFANA_PORT=3001
