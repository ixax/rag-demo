# Ollama models
OLLAMA_INSTRUCT_MODEL=llama3.2:3b
OLLAMA_EMBED_MODEL=bge-m3

# Ports exposed on the host
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334
OLLAMA_PORT=11434
OPEN_WEBUI_PORT=3000
MCP_SERVER_PORT=8000

# Qdrant collection used by the ingest and mcp-server services
QDRANT_COLLECTION=content

# Ingest mode: false (default) = incremental, only re-embeds new/changed/removed
# files (tracked via a manifest); true = full rebuild of the collection.
# `make ingest-force` sets this to true for a single run without editing .env.
FORCE_INGEST=false

# Cross-encoder reranker used by mcp-server between vector retrieval and
# generation. bge-reranker-v2-m3 is multilingual (handles Russian queries
# against the mixed-language content) and pairs naturally with the bge-m3
# embedding model above. Downloaded from Hugging Face on first use.
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# How many chunks mcp-server pulls from Qdrant before reranking, and how many
# of the reranked top results it keeps as context for the instruct model.
TOP_K_RETRIEVE=20
TOP_K_RERANK=5
