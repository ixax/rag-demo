# Full reference for every variable: README.md's "Configuration" section.

# Required, no default.
QDRANT_COLLECTION=content

# Ollama is an external deployment this repo doesn't own or manage --
# OLLAMA_HOST/OLLAMA_PORT/OLLAMA_EMBEDDINGS_MODEL/OLLAMA_REASONING_MODEL are
# all required, no default. Point OLLAMA_HOST/OLLAMA_PORT at wherever your
# Ollama instance is running. On Linux, open-webui/ingest/mcp-server already
# have the extra_hosts entry needed for host.docker.internal to resolve.
OLLAMA_HOST=host.docker.internal
OLLAMA_PORT=11434
OLLAMA_EMBEDDINGS_MODEL=embeddinggemma:300m
OLLAMA_REASONING_MODEL=

# The reranker is also an external deployment this repo doesn't own or
# manage. RERANKER_HOST is required, no default -- same reasoning as
# OLLAMA_HOST above.
RERANKER_HOST=host.docker.internal

# Optional. Host-exposed ports.
#RERANKER_PORT=50051
#QDRANT_HTTP_PORT=6333
#QDRANT_GRPC_PORT=6334
#OPEN_WEBUI_PORT=3000
#MCP_SERVER_PORT=8000
#PIPELINES_PORT=9099

PIPELINES_API_KEY=changeme

# Optional. false = incremental ingest, true = full rebuild (make ingest-force sets this itself).
FORCE_INGEST=false

# One of Python logging's level names: DEBUG, INFO, WARNING, ERROR, CRITICAL.
LOG_LEVEL=INFO

# Optional. Monitoring profile only (make monitoring-up).
#TEMPO_PORT=3200
#LOKI_PORT=3100
#PROMETHEUS_PORT=9090
#CADVISOR_PORT=8085
#NODE_EXPORTER_PORT=9101
#GRAFANA_PORT=3001
