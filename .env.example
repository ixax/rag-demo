# Models, one env var per role (MODEL_<ROLE>) -- pulled into Ollama by
# ollama-pull, except MODEL_RERANKER (Hugging Face, pulled by the reranker
# service itself) and MODEL_INSTRUCT_EXTERNAL (see the ANTHROPIC_API_KEY
# section below).
#
# Required only when services/mcp_server/config.yml's search_tools.backend.type is
# "ollama" -- leave empty (or delete the line) for
# anthropic_token/anthropic_subscription/"" backend.type, and
# services/ollama-pull/entrypoint.sh skips pulling/warming it instead of
# failing.
MODEL_INSTRUCT_INTERNAL=
# Used by both ingest and mcp-server -- they must use the exact same
# embedding model so query/document vectors are comparable.
# See README.md's "Embedding model" section for the benchmark methodology
# and results behind this choice.
MODEL_EMBED=embeddinggemma:300m

# Cross-encoder model for the reranker service (services/reranker), pulled
# from Hugging Face on first use and cached in the reranker_cache volume.
MODEL_RERANKER=BAAI/bge-reranker-v2-m3

# Optional. Defaults to the local ollama container (started via
# `make models-up`). Set to an external Ollama instance's host/IP (its port
# must be 11434) to use that instead, e.g. OLLAMA_HOST=192.168.1.50
#OLLAMA_HOST=ollama
#OLLAMA_PORT=11434

# Optional. Defaults to the local reranker container (started via
# `make reranker-up`). Set RERANKER_HOST to an external reranker instance's
# host/IP to use that instead, e.g. RERANKER_HOST=192.168.1.50 -- and
# RERANKER_PORT too if it's not on the default of 50051.
#RERANKER_HOST=reranker
#RERANKER_PORT=50051

# Optional
# Ports exposed on the host
#QDRANT_HTTP_PORT=6333
#QDRANT_GRPC_PORT=6334
#OPEN_WEBUI_PORT=3000
#MCP_SERVER_PORT=8000
#PIPELINES_PORT=9099

# Auth key open-webui and the pipelines service use to talk to each other.
# Change from the upstream default below if pipelines is ever reachable
# from outside the Docker network.
PIPELINES_API_KEY=changeme

# Qdrant collection used by the ingest and mcp-server services
QDRANT_COLLECTION=content

# Optional
# Ingest mode: false (default) = incremental, only re-embeds new/changed/removed
# files (tracked via a manifest); true = full rebuild of the collection.
# `make ingest-force` sets this to true for a single run without editing .env.
FORCE_INGEST=false

# mcp-server's reranker on/off, TOP_K_RETRIEVE/RERANK, generation
# search_tools.backend.type/max_tokens, system prompt, and the anthropic_chat tool are no
# longer set here -- they live in mcp_server/config.yml (bind-mounted, edit
# + restart, no rebuild needed). See that file, and README.md's "Claude
# subscription auth" section, for the full field reference.

# ANTHROPIC_API_KEY: only used (and only required) when search_tools.backend.type is
# "anthropic_token", or anthropic_chat.auth is "token" -- mcp-server fails
# fast at startup if it's needed and missing. Leave UNSET for
# anthropic_subscription/auth: "subscription" (uses CLAUDE_CODE_OAUTH_TOKEN
# below instead).
#
# CLAUDE_CODE_OAUTH_TOKEN: a long-lived token from `claude setup-token`
# (requires an active Claude subscription) -- only used (and only required)
# when search_tools.backend.type is "anthropic_subscription", or
# anthropic_chat.auth is "subscription". Picked up by the `claude` CLI
# subprocess itself, not read by mcp-server -- see README.md's "Claude
# subscription auth" section for how to generate it.
#
# MODEL_INSTRUCT_EXTERNAL: the Claude model for search_tools.backend.type
# "anthropic_token"/"anthropic_subscription" (required in either case).
# MODEL_CHAT: the Claude model for the standalone anthropic_chat tool
# (required when config.yml's anthropic_chat.enabled is true) -- independent
# of MODEL_INSTRUCT_EXTERNAL, so the two tools can point at different models.
# Example values: "claude-sonnet-5", "claude-opus-4-8", "claude-haiku-4-5".
ANTHROPIC_API_KEY=
CLAUDE_CODE_OAUTH_TOKEN=
MODEL_CHAT=

# Log level for ingest/mcp-server/reranker (services/_common/logging_config.py).
# One of Python logging's level names: DEBUG, INFO, WARNING, ERROR, CRITICAL.
LOG_LEVEL=INFO
