# Full reference for every variable: README.md's "Configuration" section.

# Required, no default.
QDRANT_COLLECTION=content

# Reasoning, embeddings, and reranking are all served by one external
# AI gateway this repo doesn't own or manage -- AI_GATEWAY_HOST is
# required, no default; AI_GATEWAY_PORT defaults to gateway own default port.
# Point AI_GATEWAY_HOST at wherever that gateway is running. On Linux,
# open-webui/ingest/mcp-server already have the extra_hosts entry needed for
# host.docker.internal to resolve.
AI_GATEWAY_HOST=host.docker.internal
#AI_GATEWAY_PORT=4000

# Required, no default. Sent as "<AI_GATEWAY_AUTH_HEADER>: Bearer <key>" by
# ingest/mcp-server on every AI gateway request.
AI_GATEWAY_AUTH_KEY=

# Required, no default. Header name AI_GATEWAY_AUTH_KEY is sent on --
# most gateways use "Authorization".
AI_GATEWAY_AUTH_HEADER=Authorization

# Required, no default. Template for the header value above -- "{key}" is
# replaced with AI_GATEWAY_AUTH_KEY. Most gateways use "Bearer {key}"; some
# (e.g. Anthropic's x-api-key, Azure OpenAI's api-key) take the raw key
# with no scheme prefix -- use "{key}" for those.
AI_GATEWAY_AUTH_VALUE_TEMPLATE=Bearer {key}

# AI the gateway model alias that routes to that gateway actual embedding/reasoning/reranker deployment --
# not a raw Ollama/HuggingFace/etc model tag. All three are required, no default.
AI_GATEWAY_EMBEDDINGS_MODEL=
AI_GATEWAY_REASONING_MODEL=
AI_GATEWAY_RERANKER_MODEL=

# Optional. Host-exposed ports.
#QDRANT_HTTP_PORT=6333
#QDRANT_GRPC_PORT=6334
#OPEN_WEBUI_PORT=3000
#MCP_SERVER_PORT=8000
#PIPELINES_PORT=9099

PIPELINES_API_KEY=changeme

# Optional. false = incremental ingest, true = full rebuild (make ingest-force sets this itself).
FORCE_INGEST=false

# One of Python logging's level names: DEBUG, INFO, WARNING, ERROR, CRITICAL.
LOG_LEVEL=INFO

# Optional. Monitoring profile only (make monitoring-up).
#TEMPO_PORT=3200
#LOKI_PORT=3100
#PROMETHEUS_PORT=9090
#CADVISOR_PORT=8085
#NODE_EXPORTER_PORT=9101
#GRAFANA_PORT=3001
